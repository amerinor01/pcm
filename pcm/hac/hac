    #    action='store_true',
    #    help="If this flag is given when compiling, optimization passes are applied."
    # )

    parser = argparse.ArgumentParser(
        description="The PCM handler compiler"    
    )
    parser.add_argument(
       "-c",
       "--codegen",
       action='store_true',
       required=False,
       help="Generate <algo_name>_.h and <algo_name>_pcmc_spec.cpp files from algorithm YAML config (--algoconf option)"
    )
    parser.add_argument(
        "-a",
        "--algoconf",
        required=True,
        help="path to algorithm configuration <algo_name>.yaml file",
    )
    parser.add_argument(
        "-o",
        "--output",
        default=".",
        help="path to output directory",
    )
    parser.add_argument(
        "-f",
        "--fabricconf",
        required=True,
        help="path to fabric.yaml file"
    )

    args = parser.parse_args()
    if args.codegen:
        generator = codegen.AlgorithmCodeGenerator(args.fabricconf, args.algoconf)
        generator.run(args.output)

    else:
        sys.exit("Other options are not supported yet");
