#!/usr/bin/env python3

# The PCM handler compiler.
#
# This compiler has multiple purposes/modes:
# * Generating host code necessary to instantiate a PCM handler - this could
#   be written by hand by a user, however, several things need to be in sync
#   between the PCM handler and the host code, so we offer this as a
#   convenience.
# * Verifying that a given PCM handler adheres to the UE spec, i.e., always
#   terminates in finite time, does not access memory outside of its own
#   state, etc.
# * Compiling a handler in unoptimized form, using clang or gcc - this mainly
#   exists so that we can verify that our handler specific optimizations do
#   not alter the semantics of a handler.
# * Optimizing and compiling a handler using clang and custom optimization
#   passes that make use of knowledge of the specific PCM implementation.

import sys
import argparse
import codegen

def main() -> None:
    # TODO: support options below
    # parser.add_argument(
