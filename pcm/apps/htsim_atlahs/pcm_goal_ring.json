{
  "binary": "./build/bin/htsim_flow_app_atlahs",
  "input_files": [
    "./apps/htsim_atlahs/example_ring/16_nodes_tag_large_diff.bin -nodes 16 -topo ./apps/htsim_atlahs/example_ring/tree16.topo"
  ],
  "htsim_params": "-end 30000",
  "run_without_pcm": true,
  "baseline_config": "-sender_cc_only",
  "pcm_delay_config": "-pcm_sched_poll_delay 1000 -pcm_handler_delay 1000",
  "native_nscc_baseline_file": [],
  "native_nscc_config_file": [
    "-pcm_cc_config_file ./apps/htsim_atlahs/example_ring/nscc_config.json"
  ],
  "pcm_cc_config_file": 
  [
    "-pcm_enable -pcm_cc_config_file ./apps/htsim_atlahs/example_ring/pcm_cc_config.json",
    "-pcm_enable -pcm_cc_config_file ./apps/htsim_atlahs/example_ring/pcm_cc_config_1.json",
    "-pcm_enable -pcm_cc_config_file ./apps/htsim_atlahs/example_ring/pcm_cc_config_2.json"
  ]
}