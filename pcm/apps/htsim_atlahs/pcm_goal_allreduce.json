{
  "binary": "./build/bin/htsim_flow_app_atlahs",
  "input_files": [
    "./apps/htsim_atlahs/example_allreduce/allreduce_tree_artificial.bin -nodes 32 -topo ./apps/htsim_atlahs/example_allreduce/tree1.topo"
  ],
  "htsim_params": "-end 30000",
  "run_without_pcm": true,
  "baseline_config": "-sender_cc_only",
  "pcm_delay_config": "-pcm_sched_poll_delay 1000 -pcm_handler_delay 1000",
  "native_nscc_baseline_file": [],
  "native_nscc_config_file": [
    "-pcm_cc_config_file ./apps/htsim_atlahs/example_allreduce/nscc_config.json"
  ],
  "pcm_cc_config_file": 
  [
    "-pcm_enable -pcm_cc_config_file ./apps/htsim_atlahs/example_allreduce/pcm_cc_config.json"
  ]
}
