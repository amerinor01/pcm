{
  "binary": "./build/bin/htsim_flow_app_v2",
  "input_files": [
    "./apps/htsim/permutation_128_1MB.cm"
  ],
  "htsim_params": "-topo ./apps/htsim/fat_tree_128_4os.topo -end 30000",
  "run_without_pcm": true,
  "baseline_config": "-sender_cc_algo",
